# Copy this file to .env and fill in values.
# .env is gitignored; .env.example is committed.

# Signs session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-please

# Optional: promote this username to admin on server start.
# The user must register themselves first; restart the container
# after registration to apply the promotion.
ADMIN_USERNAME=

# Optional: override defaults
# PORT=9889
# DATA_DIR=/data

# --- Auth mode -------------------------------------------------------------
# "local" (default) = built-in username/password. Works out of the box.
# "sso"             = trust forward-auth headers from an upstream IdP. Only
#                     enable when the server is behind a proxy that strips
#                     and re-sets these headers on every request. Exposing
#                     the port directly in SSO mode lets any client forge
#                     identity via headers.
AUTH_MODE=local
# Header names (defaults match Authentik). Change if your IdP uses different ones.
SSO_HEADER_USERNAME=X-authentik-username
SSO_HEADER_GROUPS=X-authentik-groups
# Members of this group are promoted to admin in SSO mode. Blank = nobody.
SSO_ADMIN_GROUP=
